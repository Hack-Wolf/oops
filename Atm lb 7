import java.util.Scanner;
class Main{
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        ATM a = new ATM();
        int choice=0;
        do{
             System.out.println("ATM MENU");
        System.out.println("enter your choice");
        System.out.println("1:Check balance");
        System.out.println("2:Withdrawal");
        System.out.println("3:Deposit");
        System.out.println("4:Exit");
        
        try{
            choice = sc.nextInt();
            switch(choice){
            case 1:
                a.display();
                break;
            case 2:
                System.out.println("Enter the amount you want to withdraw");
                float wamount = sc.nextFloat();
                a.withdrawal(wamount);
                break;
            case 3:
                System.out.println("Enter the amount you want to deposit");
                float damount = sc.nextFloat();
                a.deposit(damount);
                break;
            case 4:
                System.out.println("Exiting the program");
    
        }
        }
catch(ArithmeticException e){
    System.out.println("Error: Amount cant be 0");
}
finally{
    System.out.println("Transaction proccesed");
}
}while(choice!=4);
        
    }
}
class ATM{
    private float balance = 50000;
    public void display(){
        System.out.println("The current balance is "+ balance);
    }
    public void withdrawal(float amount){
        if(amount> balance){
            throw new ArithmeticException("Amount must below balance");
        }
        if (amount <= 0){
            throw new ArithmeticException("Amount must below 0");
        }
        balance = balance - amount;
        System.out.println(" Withdrawal sucessfull!! Amount left is "+ balance);
        
    }
    public void deposit(float amount){
        if (amount <= 0){
            throw new ArithmeticException("Amount must below 0");
        }
        balance = balance + amount;
        System.out.println(" Deposit sucessfull!! Amount is "+ balance);
    }
}

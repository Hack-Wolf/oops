class Product{
    String name;
    int price;
    public Product(String name, int price){
        this.name=name;
        this.price=price;
    }
    
    public int display (int quantity){
        int t = quantity*price;
        System.out.println("The total for " + quantity + " " +name+ " (s) is: "+t);
        return t;
    }
}
import java.util.Scanner;
class Main{
public static void main(String[] args){
	Scanner sc = new Scanner(System.in);
	double a, b;
	System.out.println("Calculator\n");
	try{
	System.out.println("Enter first no.\n");
	a=sc.nextDouble();
	System.out.println("Enter second no. \n");
	b=sc.nextDouble();
	}
	catch(Exception e){
	    System.out.println("ERROR : Enter a valid numeric value");
	    return;
	}
	
	while(true){
	    System.out.println("\nCalculator Main Menu \n 1:ADDITION \n 2:SUBTRACTION \n 3:MULTIPLICATION \n 4:DIVISION \n 5: MODULUS\n 6:EXIT\n ");
